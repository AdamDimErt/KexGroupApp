# ═══════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════
POSTGRES_URL=postgresql://root:root@127.0.0.1:5434/dashboard
REDIS_URL=redis://localhost:6380

# ═══════════════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════════════
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_BLOCK_DURATION_SECONDS=900
DEV_BYPASS_PHONES=+77074408018,+77000000001
DEV_BYPASS_CODE=111111
TELEGRAM_GATEWAY_TOKEN=CHANGE_ME
MOBIZON_API_KEY=CHANGE_ME
MOBIZON_API_DOMAIN=api.mobizon.kz

# ═══════════════════════════════════════════════════
# IIKO
# ═══════════════════════════════════════════════════
# iiko Cloud API (optional, не используется в текущей синхронизации)
IIKO_API_URL=https://api-ru.iiko.services
IIKO_API_KEY=CHANGE_ME
# iiko Server API (REQUIRED — нет fallback, throw на старте)
IIKO_SERVER_URL=https://your-org.iiko.it:443/resto/api
IIKO_LOGIN=CHANGE_ME
IIKO_PASSWORD=CHANGE_ME
IIKO_SYNC_INTERVAL_MINUTES=15
IIKO_REQUEST_TIMEOUT_MS=30000
IIKO_MAX_RETRIES=3
IIKO_CIRCUIT_BREAKER_MAX_FAILURES=3
IIKO_CIRCUIT_BREAKER_RESET_MINUTES=15
# Tenant ID (single-tenant deployment): UUID существующего Tenant в БД
TENANT_ID=

# ═══════════════════════════════════════════════════
# 1C OData (REQUIRED — aggregator-worker throws on startup if missing)
# ═══════════════════════════════════════════════════
# Canonical vars read by apps/aggregator-worker/src/onec/onec-sync.service.ts:
ONEC_BASE_URL=https://your-1c-server           # REQUIRED — base URL, NO trailing /odata (service appends path)
ONEC_USER=CHANGE_ME                            # REQUIRED — 1C OData HTTP basic auth username
ONEC_PASSWORD=CHANGE_ME                        # REQUIRED — 1C OData HTTP basic auth password
# Legacy aliases (DEPRECATED — kept for back-compat, prefer canonical names above):
ONEC_REST_URL=https://your-server/odata/standard.odata
ONEC_REST_USER=CHANGE_ME
ONEC_REST_PASS=CHANGE_ME
# Sync tuning:
ONEC_SYNC_INTERVAL_MINUTES=15
ONEC_REQUEST_TIMEOUT_MS=60000
ONEC_MAX_RETRIES=3

# ═══════════════════════════════════════════════════
# API GATEWAY
# ═══════════════════════════════════════════════════
API_GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
FINANCE_SERVICE_URL=http://localhost:3002
SERVICE_KEY=CHANGE_ME_MIN_32_CHARS
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ═══════════════════════════════════════════════════
# FIREBASE (Push)
# ═══════════════════════════════════════════════════
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# ═══════════════════════════════════════════════════
# NOTIFICATIONS / ALERTS
# ═══════════════════════════════════════════════════
ALERT_TG_BOT_TOKEN=CHANGE_ME
ALERT_TG_CHAT_ID=CHANGE_ME
# AlertService thresholds (aggregator-worker)
ALERT_SYNC_FAILURE_MINUTES=60
ALERT_LOW_REVENUE_PERCENT=70
ALERT_LARGE_EXPENSE_AMOUNT=500000
ALERT_REVENUE_AVG_DAYS=30
ALERT_COOLDOWN_HOURS=4

# ═══════════════════════════════════════════════════
# SENTRY
# ═══════════════════════════════════════════════════
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ═══════════════════════════════════════════════════
# MOBILE
# ═══════════════════════════════════════════════════
EXPO_PUBLIC_API_URL=http://192.168.0.10:3000
EXPO_PUBLIC_SENTRY_DSN=

# ═══════════════════════════════════════════════════
# TIMEZONE
# ═══════════════════════════════════════════════════
TZ=Asia/Almaty
BUSINESS_TIMEZONE=Asia/Almaty
