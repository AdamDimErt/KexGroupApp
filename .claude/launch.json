{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api-gateway",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev", "--prefix", "apps/api-gateway"],
      "port": 3000
    },
    {
      "name": "auth-service",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev", "--prefix", "apps/auth-service"],
      "port": 3001
    },
    {
      "name": "finance-service",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev", "--prefix", "apps/finance-service"],
      "port": 3002
    },
    {
      "name": "aggregator-worker",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev", "--prefix", "apps/aggregator-worker"],
      "port": 3003
    },
    {
      "name": "web-dashboard",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev", "--prefix", "apps/web-dashboard"],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "mobile-dashboard",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "cd", "apps\\mobile-dashboard", "&&", "npx", "expo", "start", "--web", "--port", "8081"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "agent-server",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "node", "tools/agent-server/index.js"],
      "port": 3010
    }
  ]
}
