    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.60.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~54.0.0",
    "expo-device": "~7.1.0",
